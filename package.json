{
  "name": "worthlane",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo run dev",
    "desktop:native:dev": "corepack pnpm --filter @worthlane/desktop-native native:dev",
    "desktop:native:pack:local": "corepack pnpm --filter @worthlane/desktop-native pack:win:local",
    "desktop:native:dist": "corepack pnpm --filter @worthlane/desktop-native dist:win",
    "desktop:native:verify": "corepack pnpm --filter @worthlane/desktop-native verify:packaged",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke:household-demo": "node scripts/smoke-household-demo.mjs",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
