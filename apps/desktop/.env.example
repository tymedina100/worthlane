# Server-only URL for the shared Worthlane API. Do not expose it through a
# NEXT_PUBLIC_ variable; desktop browser requests use same-origin route handlers.
WORTHLANE_API_URL=http://localhost:3001/api

# Server-only secret shared with the API. In production this lets the desktop
# proxy preserve per-client registration rate limits without exposing the value.
WORTHLANE_DESKTOP_PROXY_SECRET=your-desktop-proxy-secret
