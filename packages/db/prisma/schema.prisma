generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  biometricEnabled Boolean  @default(false)
  pushToken        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts              Account[]
  transactions          Transaction[]
  categories            Category[]
  budgets               Budget[]
  goals                 Goal[]
  goalContributions     GoalContribution[]
  streaks               Streak[]
  nudges                Nudge[]
  passwordResetTokens   PasswordResetToken[]
  netWorthSnapshots     NetWorthSnapshot[]
  recurringTransactions RecurringTransaction[]
  upcomingObligations   UpcomingObligation[]
  plaidItems            PlaidItem[]
  householdMemberships  HouseholdMember[]
  refreshSessions       RefreshSession[]
}

// Refresh tokens are opaque client credentials. Only a SHA-256 digest is
// persisted, while the signed JWT identifies this row and its rotation family.
// Consumed rows remain as replay-detection records until their user is deleted.
model RefreshSession {
  id           String    @id
  userId       String
  familyId     String
  tokenHash    String    @unique @db.VarChar(64)
  expiresAt    DateTime
  rotatedAt    DateTime?
  revokedAt    DateTime?
  replacedById String?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  LOAN
  OTHER
}

enum AccountSource {
  PLAID
  MANUAL
}

model Account {
  id              String        @id @default(cuid())
  userId          String
  plaidAccountId  String?       @unique
  plaidItemId     String?
  plaidCursor     String? // for transactions sync
  name            String
  institutionName String?
  type            AccountType
  source          AccountSource @default(MANUAL)
  currentBalance  Decimal       @db.Decimal(12, 2)
  lastSyncedAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  householdAccesses HouseholdAccountAccess[]
}

model Category {
  id       String  @id @default(cuid())
  name     String
  icon     String // emoji or icon name
  color    String // hex color
  isSystem Boolean @default(false) // system defaults (userId = null)
  userId   String?

  user                      User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions              Transaction[]
  budgets                   Budget[]
  householdResponsibilities HouseholdResponsibility[]

  @@unique([userId, name])
}

model Transaction {
  id                 String   @id @default(cuid())
  userId             String
  accountId          String
  plaidTransactionId String?  @unique
  amount             Decimal  @db.Decimal(12, 2) // positive = expense, negative = income
  date               DateTime
  merchantName       String?
  categoryId         String?
  isManual           Boolean  @default(false)
  isImpulse          Boolean  @default(false) // user-flagged impulse purchase
  note               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([accountId])
  @@index([categoryId])
}

enum BudgetPeriodType {
  MONTHLY
  WEEKLY
}

model Budget {
  id         String           @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal          @db.Decimal(12, 2)
  period     BudgetPeriodType @default(MONTHLY)
  rollover   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category       @relation(fields: [categoryId], references: [id])
  periods  BudgetPeriod[]

  @@unique([userId, categoryId])
}

model BudgetPeriod {
  id        String   @id @default(cuid())
  budgetId  String
  startDate DateTime
  endDate   DateTime
  spent     Decimal  @default(0) @db.Decimal(12, 2)

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, startDate])
}

enum GoalType {
  SAVINGS
  DEBT_PAYOFF
  PURCHASE
  EMERGENCY_FUND
}

model Goal {
  id                     String    @id @default(cuid())
  userId                 String
  name                   String
  targetAmount           Decimal   @db.Decimal(12, 2)
  currentAmount          Decimal   @default(0) @db.Decimal(12, 2)
  targetDate             DateTime?
  type                   GoalType
  icon                   String?
  linkedBudgetCategoryId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([userId, createdAt])
}

enum StreakType {
  DAILY_CHECKIN
  WEEKLY_ON_BUDGET
  NO_IMPULSE_PURCHASES
}

model Streak {
  id             String     @id @default(cuid())
  userId         String
  type           StreakType
  currentCount   Int        @default(0)
  longestCount   Int        @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum NudgeType {
  BUDGET_WARNING
  STREAK_AT_RISK
  GOAL_MILESTONE
  WEEKLY_SUMMARY
  IMPULSE_FLAG
  BILL_DUE
}

model Nudge {
  id        String    @id @default(cuid())
  userId    String
  type      NudgeType
  message   String
  sentAt    DateTime  @default(now())
  day       DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  dismissed Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, day])
  @@index([userId, dismissed])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PlaidItemStatus {
  HEALTHY
  NEEDS_RELINK
  ERROR
  PENDING_EXPIRATION
}

// Stores Plaid access tokens per institution (item)
model PlaidItem {
  id                   String          @id @default(cuid())
  userId               String
  itemId               String          @unique // Plaid item_id
  accessTokenEncrypted String
  institution          String?
  status               PlaidItemStatus @default(HEALTHY)
  needsRelink          Boolean         @default(false)
  errorCode            String?
  errorMessage         String?
  syncCursor           String?
  lastSyncAt           DateTime?
  lastWebhookAt        DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum UpcomingObligationType {
  BILL
  CREDIT_CARD
  SUBSCRIPTION
  OTHER
}

// User-entered obligations are separate from Plaid-derived recurring data so
// V1 stays reliable without a bank connection.
model UpcomingObligation {
  id             String                 @id @default(cuid())
  userId         String
  name           String
  amount         Decimal                @db.Decimal(12, 2)
  dueDate        DateTime               @db.Date
  type           UpcomingObligationType @default(BILL)
  frequency      RecurringFrequency?
  accountName    String?
  reminderTiming String?
  isPaid         Boolean                @default(false)
  isActive       Boolean                @default(true)
  lastPaidAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, isPaid, dueDate])
}

// Detected recurring merchants (subscriptions, bills). Rows are produced by
// the detector in apps/api/src/lib/recurring.ts and refreshed after Plaid
// syncs and by the daily cron.
model RecurringTransaction {
  id                 String             @id @default(cuid())
  userId             String
  normalizedMerchant String
  displayName        String
  categoryId         String?
  accountId          String?
  averageAmount      Decimal            @db.Decimal(12, 2)
  frequency          RecurringFrequency
  lastSeenDate       DateTime
  nextDueDate        DateTime
  occurrenceCount    Int
  isActive           Boolean            @default(true)
  isMuted            Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedMerchant, frequency])
  @@index([userId, nextDueDate])
}

// Daily net worth snapshot per user (table created in 20260317000000_add_net_worth_snapshot)
model NetWorthSnapshot {
  id       String   @id @default(cuid())
  userId   String
  netWorth Decimal  @db.Decimal(12, 2)
  date     DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum HouseholdMemberStatus {
  INVITED
  ACTIVE
  LEFT
  REMOVED
}

enum AccountVisibility {
  PERSONAL
  SUMMARY
  SHARED
}

enum ResponsibilityMode {
  MEMBER
  EQUAL
  PERCENTAGE
}

enum GoalContributionMode {
  EQUAL
  CUSTOM
  INCOME_PROPORTIONAL
}

model Household {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  timezone  String   @default("UTC")
  currency  String   @default("USD") @db.VarChar(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          HouseholdMember[]
  accountAccesses  HouseholdAccountAccess[]
  responsibilities HouseholdResponsibility[]
  goals            HouseholdGoal[]
}

model HouseholdMember {
  id          String                @id @default(cuid())
  householdId String
  userId      String?
  displayName String
  role        HouseholdRole         @default(MEMBER)
  status      HouseholdMemberStatus @default(INVITED)
  incomeBasis Decimal?              @db.Decimal(12, 2)
  joinedAt    DateTime?
  endedAt     DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  household                 Household                           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user                      User?                               @relation(fields: [userId], references: [id], onDelete: SetNull)
  accountAccesses           HouseholdAccountAccess[]
  responsibilityAllocations HouseholdResponsibilityAllocation[]
  goalParticipants          HouseholdGoalParticipant[]
  goalContributions         HouseholdGoalContribution[]

  @@unique([householdId, userId])
  // PostgreSQL additionally enforces one ACTIVE membership per non-null user
  // through a partial unique index in the additive migration.
  @@index([userId, status])
  @@index([householdId, status])
}

model HouseholdAccountAccess {
  id          String            @id @default(cuid())
  householdId String
  accountId   String
  memberId    String
  visibility  AccountVisibility @default(PERSONAL)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  household Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member    HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([accountId, memberId])
  @@index([householdId, memberId, visibility])
}

model HouseholdResponsibility {
  id            String             @id @default(cuid())
  householdId   String
  categoryId    String?
  slug          String
  name          String
  monthlyAmount Decimal            @db.Decimal(12, 2)
  mode          ResponsibilityMode
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  household   Household                           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category    Category?                           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  allocations HouseholdResponsibilityAllocation[]

  @@unique([householdId, slug])
  @@index([householdId, isActive])
  @@index([categoryId])
}

model HouseholdResponsibilityAllocation {
  id               String @id @default(cuid())
  responsibilityId String
  memberId         String
  shareBasisPoints Int?

  responsibility HouseholdResponsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)
  member         HouseholdMember         @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([responsibilityId, memberId])
  @@index([memberId])
}

model HouseholdGoal {
  id               String               @id @default(cuid())
  householdId      String
  slug             String
  name             String
  targetAmount     Decimal              @db.Decimal(12, 2)
  targetDate       DateTime?
  type             GoalType             @default(SAVINGS)
  icon             String?
  contributionMode GoalContributionMode
  isArchived       Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  household     Household                   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  participants  HouseholdGoalParticipant[]
  contributions HouseholdGoalContribution[]

  @@unique([householdId, slug])
  @@index([householdId, isArchived])
  @@index([householdId, targetDate])
}

model HouseholdGoalParticipant {
  id                 String   @id @default(cuid())
  goalId             String
  memberId           String
  customTargetAmount Decimal? @db.Decimal(12, 2)

  goal   HouseholdGoal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  member HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([goalId, memberId])
  @@index([memberId])
}

model HouseholdGoalContribution {
  id              String   @id @default(cuid())
  goalId          String
  memberId        String?
  contributorName String
  amount          Decimal  @db.Decimal(12, 2)
  note            String?
  createdAt       DateTime @default(now())

  goal   HouseholdGoal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  member HouseholdMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([goalId, createdAt])
  @@index([memberId, createdAt])
}
